{
  "_version": "1.0.0",
  "_updatedAt": "2026-04-22",
  "_comment": "Dispatcher-Worker 오케스트레이션 단일 원천. 스킬·에이전트·프롬프트는 이 파일을 Read하여 참조. 직접 편집 허용. 값 변경 시 스킬 재배포 불필요.",

  "models": {
    "agentToolAliases": {
      "sonnet": "sonnet",
      "opus":   "opus",
      "haiku":  "haiku"
    },
    "fullIdentifiers": {
      "sonnet": "claude-sonnet-4-6",
      "opus":   "claude-opus-4-7"
    }
  },

  "gradePolicies": {
    "S": { "mainModel": "opus",   "subModel": "opus",   "dispatchSubs": true,  "note": "메타 결정·전면 재설계 — 오케스트레이션 판단도 Opus 급 필요" },
    "A": { "mainModel": "sonnet", "subModel": "opus",   "dispatchSubs": true,  "note": "일반 전략 토픽 — 서브 Opus로 역할 품질 확보, 메인 Sonnet으로 비용 절감" },
    "B": { "mainModel": "sonnet", "subModel": "sonnet", "dispatchSubs": false, "note": "경량 토픽 — 서브화 불필요, Sonnet 단일로 충분" },
    "C": { "mainModel": "sonnet", "subModel": null,     "dispatchSubs": false, "note": "Dev 직행 토픽 — 오케스트레이션 불필요" }
  },

  "dispatchableRoles": ["ace", "arki", "fin", "riki"],
  "skillInjectionRoles": ["ace"],

  "roleSubAgentFiles": {
    "ace":  ".claude/agents/role-ace.md",
    "arki": ".claude/agents/role-arki.md",
    "fin":  ".claude/agents/role-fin.md",
    "riki": ".claude/agents/role-riki.md"
  },

  "contextLayers": {
    "fixed": {
      "source": "CLAUDE.md",
      "maxTokens": 3000,
      "sections": ["Operating Protocol", "Role definitions", "Schedule-on-Demand"]
    },
    "dynamic": {
      "framingMaxTokens": 5000,
      "previousRolesMode": "file-path-list",
      "roleMemoryMode": "file-path-ref"
    },
    "totalBudgetTokens": 30000,
    "fallback": {
      "onBudgetExceed": "downgrade-previous-roles-to-path-list"
    }
  },

  "filePaths": {
    "reportTemplate":     "reports/{date}_{slug}/{role}_rev{n}.md",
    "roleMemoryTemplate": "memory/roles/{role}_memory.json",
    "dispatchConfig":     "memory/shared/dispatch_config.json",
    "skillBase":          ".claude/skills"
  },

  "guardrails": {
    "maxSubRecallsPerSession": 5,
    "rollbackTriggers": {
      "costSavingsBelowPct":         30,
      "masterSignalMissCount":        2,
      "masterSignalWindowSessions":   3
    }
  },

  "defaults": {
    "dispatchMode": "dispatcher"
  }
}
